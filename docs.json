          "features/overview",
          "features/teams",
          "features/agents",
          "features/providers-and-models"
        ]
      },
      {
        "group": "Reference",
        "pages": [
          "reference/team-templates",
          "guides/agent-marketplace/built-in-syndicate-agents",
